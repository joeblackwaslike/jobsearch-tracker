{
  "manifest_version": 3,
  "name": "Job Search Tracker",
  "version": "0.1.0",
  "description": "One-click job application tracking from any job board.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "src/assets/icons/icon-gray-16.png",
    "32": "src/assets/icons/icon-gray-32.png",
    "48": "src/assets/icons/icon-gray-48.png",
    "128": "src/assets/icons/icon-gray-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Job Search Tracker",
    "default_icon": {
      "16": "src/assets/icons/icon-gray-16.png",
      "32": "src/assets/icons/icon-gray-32.png",
      "48": "src/assets/icons/icon-gray-48.png",
      "128": "src/assets/icons/icon-gray-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.indeed.com/*",
        "*://boards.greenhouse.io/*",
        "*://job-boards.greenhouse.io/*",
        "*://*.ashbyhq.com/*",
        "*://*.lever.co/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.wellfound.com/*",
        "*://*.builtin.com/*",
        "*://*.dice.com/*",
        "*://*.levels.fyi/*",
        "*://*.ziprecruiter.com/*",
        "*://github.com/*/jobs*",
        "*://github.careers/*",
        "*://www.github.careers/*",
        "*://www.google.com/search*",
        "*://www.teamblind.com/*",
        "*://*.welcometothejungle.com/*",
        "*://www.workatastartup.com/*",
        "*://apply.workable.com/*",
        "*://news.ycombinator.com/jobs*",
        "*://news.ycombinator.com/item*",
        "*://www.ycombinator.com/companies/*/jobs/*",
        "*://ycombinator.com/companies/*/jobs/*",
        "*://aijobs.net/job/*",
        "*://www.aijobs.net/job/*",
        "*://startup.jobs/*",
        "*://www.startup.jobs/*"
      ],
      "js": [
        "src/content/index.ts"
      ],
      "run_at": "document_idle"
    }
  ]
}
